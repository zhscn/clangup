# Linux bootstrap and runtime configuration for the default channel.

set(_bootstrap "$ENV{CLANGUP_BOOTSTRAP_PREFIX}")
set(_builder "$ENV{CLANGUP_BUILDER_PREFIX}")

set(LLVM_ENABLE_PER_TARGET_RUNTIME_DIR OFF CACHE BOOL "" FORCE)
set(LLVM_ENABLE_ZSTD ON CACHE BOOL "" FORCE)
set(LLVM_BUILD_LLVM_DYLIB ON CACHE BOOL "" FORCE)
set(LLVM_LINK_LLVM_DYLIB ON CACHE BOOL "" FORCE)
set(CLANG_LINK_CLANG_DYLIB ON CACHE BOOL "" FORCE)

set(CMAKE_PREFIX_PATH "${_builder}" CACHE PATH "" FORCE)
set(CMAKE_C_COMPILER "${_bootstrap}/bin/clang" CACHE FILEPATH "" FORCE)
set(CMAKE_CXX_COMPILER "${_bootstrap}/bin/clang++" CACHE FILEPATH "" FORCE)
set(CMAKE_AR "${_bootstrap}/bin/llvm-ar" CACHE FILEPATH "" FORCE)
set(CMAKE_NM "${_bootstrap}/bin/llvm-nm" CACHE FILEPATH "" FORCE)
set(CMAKE_RANLIB "${_bootstrap}/bin/llvm-ranlib" CACHE FILEPATH "" FORCE)

set(_linker_flags
    "--rtlib=compiler-rt --unwindlib=none -Wl,--no-as-needed,-l:libgcc_s.so.1,--as-needed")

set(CMAKE_EXE_LINKER_FLAGS "${_linker_flags}" CACHE STRING "" FORCE)
set(CMAKE_SHARED_LINKER_FLAGS "${_linker_flags}" CACHE STRING "" FORCE)

set(RUNTIMES_CMAKE_ARGS
    "-C$ENV{CLANGUP_BUILD_CONFIG_DIR}/linux-runtimes.cmake"
    CACHE STRING "" FORCE)

set(LLVM_ENABLE_LLD ON CACHE BOOL "" FORCE)
set(LLVM_ENABLE_LIBCXX ON CACHE BOOL "" FORCE)
set(LLVM_STATIC_LINK_CXX_STDLIB ON CACHE BOOL "" FORCE)
set(LLVM_PARALLEL_LINK_JOBS "$ENV{CLANGUP_LINK_JOBS}" CACHE STRING "" FORCE)

set(COMPILER_RT_BUILD_SANITIZERS ON CACHE BOOL "" FORCE)
set(COMPILER_RT_DEFAULT_TARGET_ONLY ON CACHE BOOL "" FORCE)
set(COMPILER_RT_BUILD_LIBFUZZER ON CACHE BOOL "" FORCE)
set(COMPILER_RT_BUILD_PROFILE ON CACHE BOOL "" FORCE)
set(COMPILER_RT_USE_LIBCXX OFF CACHE BOOL "" FORCE)
set(LIBCXX_ENABLE_SHARED OFF CACHE BOOL "" FORCE)
set(LIBCXX_ENABLE_STATIC ON CACHE BOOL "" FORCE)
set(LIBCXX_ENABLE_STATIC_ABI_LIBRARY ON CACHE BOOL "" FORCE)
set(LIBCXX_INSTALL_INCLUDE_DIR
    "$ENV{CLANGUP_PREFIX}/include/c++/v1" CACHE PATH "" FORCE)
set(LIBCXX_INSTALL_INCLUDE_TARGET_DIR
    "$ENV{CLANGUP_PREFIX}/include/c++/v1" CACHE PATH "" FORCE)
set(LIBCXX_INSTALL_LIBRARY_DIR
    "$ENV{CLANGUP_PREFIX}/lib" CACHE PATH "" FORCE)
set(LIBCXXABI_ENABLE_SHARED OFF CACHE BOOL "" FORCE)
set(LIBCXXABI_ENABLE_STATIC ON CACHE BOOL "" FORCE)
set(LIBCXXABI_INSTALL_INCLUDE_DIR
    "$ENV{CLANGUP_PREFIX}/include/c++/v1" CACHE PATH "" FORCE)
set(LIBCXXABI_INSTALL_LIBRARY_DIR
    "$ENV{CLANGUP_PREFIX}/lib" CACHE PATH "" FORCE)
set(LIBCXXABI_USE_LLVM_UNWINDER OFF CACHE BOOL "" FORCE)
