# Final compiler-rt configuration for the libcxx channel.

set(_build "$ENV{CLANGUP_BUILD}")
set(_prefix "$ENV{CLANGUP_PREFIX}")
set(_resource_dir "$ENV{CLANGUP_RESOURCE_DIR}")
set(_triple "$ENV{CLANGUP_TARGET_TRIPLE}")

set(CMAKE_BUILD_TYPE Release CACHE STRING "" FORCE)
set(CMAKE_INSTALL_PREFIX "${_prefix}" CACHE PATH "" FORCE)
set(CMAKE_C_COMPILER "${_prefix}/bin/clang" CACHE FILEPATH "" FORCE)
set(CMAKE_CXX_COMPILER "${_prefix}/bin/clang++" CACHE FILEPATH "" FORCE)
set(CMAKE_C_COMPILER_TARGET "${_triple}" CACHE STRING "" FORCE)
set(CMAKE_CXX_COMPILER_TARGET "${_triple}" CACHE STRING "" FORCE)

set(COMPILER_RT_BUILD_BUILTINS OFF CACHE BOOL "" FORCE)
set(COMPILER_RT_BUILD_CRT OFF CACHE BOOL "" FORCE)
set(COMPILER_RT_BUILD_SANITIZERS ON CACHE BOOL "" FORCE)
set(COMPILER_RT_BUILD_LIBFUZZER ON CACHE BOOL "" FORCE)
set(COMPILER_RT_BUILD_PROFILE ON CACHE BOOL "" FORCE)
set(COMPILER_RT_BUILD_CTX_PROFILE ON CACHE BOOL "" FORCE)
set(COMPILER_RT_BUILD_MEMPROF ON CACHE BOOL "" FORCE)
set(COMPILER_RT_BUILD_ORC ON CACHE BOOL "" FORCE)
set(COMPILER_RT_BUILD_XRAY ON CACHE BOOL "" FORCE)
set(COMPILER_RT_BUILD_GWP_ASAN ON CACHE BOOL "" FORCE)
set(COMPILER_RT_DEFAULT_TARGET_ONLY ON CACHE BOOL "" FORCE)
set(COMPILER_RT_INCLUDE_TESTS OFF CACHE BOOL "" FORCE)
set(COMPILER_RT_INSTALL_PATH "${_resource_dir}" CACHE PATH "" FORCE)
set(COMPILER_RT_USE_BUILTINS_LIBRARY ON CACHE BOOL "" FORCE)
set(COMPILER_RT_USE_LIBCXX OFF CACHE BOOL "" FORCE)
set(LLVM_CMAKE_DIR "${_build}" CACHE PATH "" FORCE)
set(LLVM_ENABLE_PER_TARGET_RUNTIME_DIR ON CACHE BOOL "" FORCE)

set(SANITIZER_CXX_ABI libcxxabi CACHE STRING "" FORCE)
set(SANITIZER_USE_STATIC_CXX_ABI ON CACHE BOOL "" FORCE)
