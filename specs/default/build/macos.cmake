# Apple Silicon default-channel configuration.

set(CMAKE_C_COMPILER "$ENV{CLANGUP_APPLE_CLANG}" CACHE FILEPATH "" FORCE)
set(CMAKE_CXX_COMPILER "$ENV{CLANGUP_APPLE_CLANGXX}" CACHE FILEPATH "" FORCE)
set(CMAKE_OSX_ARCHITECTURES arm64 CACHE STRING "" FORCE)
set(CMAKE_OSX_DEPLOYMENT_TARGET "$ENV{CLANGUP_MIN_MACOS_VERSION}" CACHE STRING "" FORCE)
set(CMAKE_OSX_SYSROOT "$ENV{CLANGUP_MACOS_SDK}" CACHE PATH "" FORCE)
set(LLVM_ENABLE_ZSTD OFF CACHE BOOL "" FORCE)
